# Entrypoint handles first-run init on the persistent volume
COPY --chmod=755 deploy/entrypoint-fly.sh /entrypoint.sh

EXPOSE 8088

# Run as root so we can write to the Fly volume on first deploy.
# The volume is mounted by Fly.io at runtime and may need initialization.
CMD ["/entrypoint.sh"]
