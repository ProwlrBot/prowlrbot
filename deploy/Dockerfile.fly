# Init default config (no interactive prompt, no browser tools)
RUN prowlr init --defaults --accept-security

# Working directory for runtime data (config, chats, skills)
# Fly volumes mount here: fly volumes create prowlrbot_data --region <region>
ENV PROWLRBOT_WORKING_DIR=/data
VOLUME ["/data"]

EXPOSE 8088

# Run uvicorn directly (no supervisord needed without Xvfb)
CMD ["prowlr", "app", "--host", "0.0.0.0", "--port", "8088"]
