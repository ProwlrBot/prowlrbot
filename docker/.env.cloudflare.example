# docker/.env.cloudflare.example
# Copy to docker/.env.cloudflare and fill in your values.
# NEVER commit the filled-in .env.cloudflare file.

# Required: Cloudflare API token
# Create at: https://dash.cloudflare.com/profile/api-tokens
# Minimum scopes: Account:Read, Workers Scripts:Edit, Workers KV Storage:Edit,
#                 D1:Edit, R2:Edit, Workers AI:Run
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# Required: Your Cloudflare Account ID
# Find at: https://dash.cloudflare.com → right sidebar
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# Optional: Restrict to a specific zone (domain)
# Find at: https://dash.cloudflare.com → select domain → Overview → Zone ID
# CLOUDFLARE_ZONE_ID=your_zone_id_here
